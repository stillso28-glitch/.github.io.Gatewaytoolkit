# Gateway API Proxy — Vercel Environment Variables
# Add these in: Vercel Dashboard → Your Project → Settings → Environment Variables

# Anthropic Claude API key — get from https://console.anthropic.com/api-keys
CLAUDE_API_KEY=sk-ant-...

# Buffer access token — get from https://buffer.com/developers/apps
# This is the BROKERAGE account token. All agents share it.
BUFFER_ACCESS_TOKEN=...

# Shared secret between the toolkit and this proxy.
# Set the same value in config.js → proxySecret
# Generate one: openssl rand -hex 32
GATEWAY_SECRET=change-me-to-a-random-secret

# Restrict CORS to your toolkit domain (recommended in production)
# ALLOWED_ORIGIN=https://yourdomain.github.io
